{
  "buildCommand": "npm run build",
  "devCommand": "vite",
  "installCommand": "npm ci --prefer-offline --no-audit",
  "framework": "vite",
  "outputDirectory": "dist",
  "functions": {
    "api/roadmaps.ts": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/roadmaps/[id].ts": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, s-maxage=60"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
